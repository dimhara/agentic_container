# ==========================================
# STAGE 1: Builder (Heavy C++ dependencies)
# ==========================================
FROM debian:testing-slim AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential cmake git curl ca-certificates \
    libvulkan-dev glslc python3

# Build llama.cpp with Vulkan support and install to a staging directory
WORKDIR /build
RUN git clone --depth 1 https://github.com/ggml-org/llama.cpp.git . && \
    # Define an install prefix to cleanly gather binaries AND shared libs
    cmake -B build -DGGML_VULKAN=ON -DCMAKE_INSTALL_PREFIX=/opt/llama && \
    cmake --build build --config Release -j$(nproc) && \
    cmake --install build

# ==========================================
# STAGE 2: Final Inference Server (No Python!)
# ==========================================
FROM debian:testing-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    libvulkan1 vulkan-tools ca-certificates libgomp1 rocminfo mesa-vulkan-drivers less nano && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Copy the entire staged installation (contains bin/, lib/, etc.)
COPY --from=builder /opt/llama/ /usr/local/

# Update linker cache so the OS knows where to find libggml.so and libllama.so
RUN ldconfig

EXPOSE 8080
CMD ["llama-server"]
