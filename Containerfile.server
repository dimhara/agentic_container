# ==========================================
# STAGE 1: Builder (Heavy C++ dependencies)
# ==========================================
FROM python:3.12-slim AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential cmake git curl ca-certificates \
    libvulkan-dev glslc

# Build llama.cpp with Vulkan support and new ggml-org repo
WORKDIR /build
RUN git clone --depth 1 https://github.com/ggml-org/llama.cpp.git . && \
    cmake -B build -DGGML_VULKAN=ON && \
    cmake --build build --config Release -j$(nproc) && \

    strip /build/build/bin/llama-server

# ==========================================
# STAGE 2: Final Inference Server (No Python!)
# ==========================================
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    libvulkan1 vulkan-tools ca-certificates && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

COPY --from=builder /build/build/bin/llama-server /usr/local/bin/

EXPOSE 8080
CMD ["llama-server"]
