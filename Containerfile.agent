# ==========================================
# STAGE 1: Builder (Python Dependencies)
# ==========================================
FROM python:3.12-slim AS builder

RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

ENV VIRTUAL_ENV=/opt/venv
RUN uv venv $VIRTUAL_ENV
ENV PATH="$VIRTUAL_ENV/bin:$PATH"

RUN export CUTOFF_DATE=$(date -d '7 days ago' -u +'%Y-%m-%dT%H:%M:%SZ') && \
    uv pip install --no-cache --exclude-newer "$CUTOFF_DATE" aider-chat

# ==========================================
# STAGE 2: Final Agent Sandbox (Lightweight)
# ==========================================
FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates git && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

COPY --from=builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Install OpenCode and force-clear any temporary download artifacts
RUN curl -fsSL https://opencode.ai/install | bash && \
    rm -rf /tmp/* /var/tmp/*

RUN useradd -m -s /bin/bash agent
USER agent
WORKDIR /home/agent

CMD ["/bin/bash"]
