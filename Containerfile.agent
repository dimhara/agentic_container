# ==========================================
# STAGE 1: Builder (Python Dependencies)
# ==========================================
FROM python:3.12-slim AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates

# Setup uv (Astral's fast Python package manager)
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# Create a virtual environment and install Python agents
ENV VIRTUAL_ENV=/opt/venv
RUN uv venv $VIRTUAL_ENV
ENV PATH="$VIRTUAL_ENV/bin:$PATH"

# Supply Chain Protection: 7 day zero-day defense
RUN export CUTOFF_DATE=$(date -d '7 days ago' -u +'%Y-%m-%dT%H:%M:%SZ') && \
    echo "Building with PyPI cutoff date: $CUTOFF_DATE" && \
    uv pip install --exclude-newer "$CUTOFF_DATE" aider-chat

# ==========================================
# STAGE 2: Final Agent Sandbox (Lightweight)
# ==========================================
FROM python:3.12-slim

# Install ONLY runtime requirements (git for aider, curl for opencode)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates git && \
    rm -rf /var/lib/apt/lists/*

# 1. Copy over the isolated Python environment (contains Aider)
COPY --from=builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# 2. Install OpenCode directly via its standalone binary script (No npm/bun required)
RUN curl -fsSL https://opencode.ai/install | bash

# 3. Create an unprivileged user for standard operations (Security Best Practice)
RUN useradd -m -s /bin/bash agent
USER agent
WORKDIR /home/agent

# Default command (can be overridden when you run podman)
CMD ["/bin/bash"]

